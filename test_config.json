{
  "input": "inputs/test_input_100rows.csv",
  "suffix": "CHECK",
  "transforms": [
    ["D", "double_value"]
  ],
  "pivot_filters": ["G"],
  "pivot_rows": ["C"],
  "pivot_columns": ["B"],
  "pivot_value_settings": [
    {
      "column": "D",
      "summary": "sum",
      "name": "Total Amount",
      "number_format": "#,##0"
    },
    {
      "column": "E",
      "summary": "average",
      "name": "Average Score",
      "number_format": "0.0"
    }
  ]
}
