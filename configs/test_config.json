{
  "input": "inputs/test_input_100rows.csv",
  "suffix": "CHECK",
  "transforms": [
    ["Time", "time_to_seconds"],
    ["Amount", "double_value"]
  ],
  "pivot_filters": ["Channel", "Priority"],
  "pivot_rows": ["Region", "Category"],
  "pivot_columns": ["Segment", "Quarter"],
  "pivot_value_settings": [
    {
      "header": "Amount",
      "summary": "sum",
      "name": "Total Amount",
      "number_format": "#,##0"
    },
    {
      "header": "Score",
      "summary": "average",
      "name": "Average Score",
      "number_format": "0.0"
    }
  ]
}
